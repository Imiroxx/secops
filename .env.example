# Database connection (optional - falls back to in-memory storage)
# DATABASE_URL=postgresql://user:password@localhost:5432/secops?sslmode=prefer

# Node environment
NODE_ENV=production

# Session secret (generate a random string for production)
SESSION_SECRET=your-secret-key-here-change-in-production

# OpenAI API key for AI analysis features (optional)
OPENAI_API_KEY=sk-your-openai-key-here

# Base URL for QR auth
BASE_URL=https://your-site.netlify.app
